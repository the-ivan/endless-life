<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to access the Glyph Matrix -->
    <uses-permission android:name="com.nothing.ketchum.permission.ENABLE" />

    <!-- Foreground service + wake lock for AOD persistent running -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- API 34+: for specialUse fg type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        tools:targetApi="31">

        <!-- Settings UI (also used as launcher activity for manual testing). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.EndlessLife">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The actual Glyph Toy Service -->
        <service
            android:name=".EndlessLifeService"
            android:exported="true"
            android:foregroundServiceType="specialUse"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.nothing.glyph.TOY" />
            </intent-filter>

            <!-- Required metadata for the toy to appear in settings -->
            <meta-data
                android:name="com.nothing.glyph.toy.name"
                android:resource="@string/toy_name" />

            <meta-data
                android:name="com.nothing.glyph.toy.image"
                android:resource="@drawable/toy_preview" />

            <meta-data
                android:name="com.nothing.glyph.toy.summary"
                android:resource="@string/toy_summary" />

            <!-- Enables "Always-on Glyph Toy" / Flip to Glyph mode -->
            <meta-data
                android:name="com.nothing.glyph.toy.aod_support"
                android:value="1" />

            <!-- Enable long-press handling on Phone (3) -->
            <meta-data
                android:name="com.nothing.glyph.toy.longpress"
                android:value="1" />

            <!-- Justification for specialUse fg (AOD persistent) -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="ambient_glyph_aod" />
        </service>

        <!-- Nothing developer key. "test" is standard for dev + community toys. -->
        <meta-data
            android:name="NothingKey"
            android:value="test" />

    </application>

</manifest>